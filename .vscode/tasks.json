{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "CMake: Configure Debug",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--preset",
				"Debug"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "Build Debug",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"--preset",
				"Debug"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"dependsOn": [
				"CMake: Configure Debug"
			],
			"dependsOrder": "sequence"
		},
		{
			"label": "Flash Debug",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"--preset",
				"Debug",
				"--target",
				"flash"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [],
			"dependsOn": [
				"Build Debug"
			],
			"dependsOrder": "sequence"
		},
		{
			"label": "Build Select MCU",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"--preset",
				"${input:mcuBuildPreset}"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "Flash Select MCU",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"--preset",
				"${input:mcuFlashPreset}",
				"--target",
				"flash"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [],
			"dependsOn": []
		}
	],
	"inputs": [
		{
			"id": "mcuBuildPreset",
			"type": "pickString",
			"description": "选择要构建的 MCU 目标",
			"options": [
				"Debug-F103",
				"Debug-F407"
			],
			"default": "Debug-F103"
		},
		{
			"id": "mcuFlashPreset",
			"type": "pickString",
			"description": "选择要烧录的 MCU 目标",
			"options": [
				"Debug-F103",
				"Debug-F407"
			],
			"default": "Debug-F103"
		}
	]
}